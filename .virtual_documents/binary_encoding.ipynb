











import math
from pysat.solvers import Glucose3


def AMO(g, vars, start_var_id):
    n = len(vars)
    if n <= 1:
        return start_var_id
    n_bits = math.ceil(math.log2(n))
    term_vars = [start_var_id + i for i in range (n_bits)]

    for idx, x in enumerate(vars):
        for i in range (n_bits):
            if (idx >> i) & 1: #nếu bit thứ i từ phải sang bằng 1 thì lấy khẳng định của biến phụ
                g.add_clause([-x, term_vars[i]])
            else:
                g.add_clause([-x, -term_vars[i]])
    return start_var_id + n_bits


def ALO(g, vars):
    g.add_clause(vars)


def var_id(r, c, n):
    return r * n + c + 1





def solve_n_queen(n):
    
    g = Glucose3()
    next_var = n * n + 1

    # Row constraints
    for r in range(n):
        row_vars = [var_id(r, c, n) for c in range(n)]
        ALO(g, row_vars)
        next_var = AMO(g, row_vars, next_var)

    # Column constraints
    for c in range(n):
        col_vars = [var_id(r, c, n) for r in range(n)]
        ALO(g, col_vars)
        next_var = AMO(g, col_vars, next_var)

    # Main diagonals (r - c)
    for d in range(-n + 1, n):
        diag = []
        for r in range(n):
            c = r - d
            if 0 <= c < n:
                diag.append(var_id(r, c, n))
        if len(diag) > 1:
            next_var = AMO(g, diag, next_var)

    # Anti diagonals (r + c)
    for d in range(2 * n - 1):
        diag = []
        for r in range(n):
            c = d - r
            if 0 <= c < n:
                diag.append(var_id(r, c, n))
        if len(diag) > 1:
            next_var = AMO(g, diag, next_var)

    # Solve
    if g.solve():
        model = set(g.get_model())
        for r in range(n):
            row = ['.'] * n
            for c in range(n):
                if var_id(r, c, n) in model:
                    row[c] = 'Q'
            print(' '.join(row))
    else:
        print("UNSATISFIABLE")


solve_n_queen(10)





def var_id_3(r, c, k, n):
    return r*n*n + c*n + k + 1


def solve_Sudoku(n, grid):
    g = glucose3()
    next_var = n * n * n + 1
    s = int(math.sqrt(n))
    
    # cell constraints
    for r in range (n):
        for l in range (n):
            vars = [var_id_3(r, c, k, n) for k in range (n)]
            ALO(g, vars)
            next_var = AMO(g, vars, next_var)
            
    # row constraints
    for k in range (n):
        for r in range (n):
            vars = [var_id_3(r, c, k, n) for c in range (n)]
            ALO(g, vars)
            next_var = AMO(g, vars, next_var)
            
    # col constraints
    for k in range (n):
        for c in range (n):
            vars = [var_id_3(r, c, k, n) for r in range (n)]
            ALO(g, vars)
            next_var = AMO(g, vars, next_var)
            
    # matrix sqrt(n) * sqrt(n) constraints
    for k in range (n):
        for start_r in range (0, n, s):
            for start_c in range (0, n, s):
                vars = []
                for d in range (n):
                    r = start_r + d//n;
                    c = start_c + d%n;
                    vars.append(var_id_3(r, c, k, n))
                ALO(g, vars)
                next_var = AMO(g, vars, next_var)

    if g.solve():
        model = g.get_model()
        for i in range(n):
            for j in range(n):
                for k in range(n):
                    if vars[i][j][k] in model:
                        print(k+1, end = ' ')
            print("\n")
    else:
        print("UNSATISFIABLE")
                
            
    


grid = [
    [5,3,0,0,7,0,0,0,0],
    [6,0,0,1,9,5,0,0,0],
    [0,9,8,0,0,0,0,6,0],
    [8,0,0,0,6,0,0,0,3],
    [4,0,0,8,0,3,0,0,1],
    [7,0,0,0,2,0,0,0,6],
    [0,6,0,0,0,0,2,8,0],
    [0,0,0,4,1,9,0,0,5],
    [0,0,0,0,8,0,0,7,9],
]


solve_Sudoku(9, grid)



