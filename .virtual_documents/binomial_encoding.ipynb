# create a SAT Slover instance (glucose3)
with Glucose3() as g:
    #Add clauses to the solver
    g.add_clause([1, -2]) #x1 ∨ ¬x2
    g.add_clause([2, 3]) #x2 ∨ x3

    if g.solve():
        print("SATISFIABLES")
        print("Model: ", g.get_model()) #Get the model (Satisfying assignment) TTT
    else:
        print("UNSATISFIABLES")








def solve(n):
    pos = [-1] * n

    used_col = set()
    diag1 = set()  # row - col
    diag2 = set()  # row + col

    def backtrack(row):
        if row == n:
            print_board(pos)
            return
        
        for col in range(n):
            if col in used_col:
                continue
            
            if (row - col) in diag1:
                continue
            
            if (row + col) in diag2:
                continue

            pos[row] = col
            used_col.add(col)
            diag1.add(row - col)
            diag2.add(row + col)

            backtrack(row + 1)


            used_col.remove(col)
            diag1.remove(row - col)
            diag2.remove(row + col)
            pos[row] = -1

    backtrack(0)


def print_board(pos):
    n = len(pos)
    for i in range(n):
        row = ['.'] * n
        row[pos[i]] = 'Q'
        print(' '.join(row))


solve(4)























def solve_nqueens(n):
    from pysat.solvers import Glucose3
    
    with Glucose3() as g:
        vars = [[(i * n + j + 1) for j in range(n)] for i in range(n)]

        # Exactly one for each row
        for i in range(n):
            g.add_clause(vars[i])  # ALO
            for j in range(n):
                for k in range(j + 1, n):
                    g.add_clause([-vars[i][j], -vars[i][k]])  # AMO

        # Exactly one for each column
        for j in range(n):
            g.add_clause([vars[i][j] for i in range(n)])  # ALO
            for i in range(n):
                for k in range(i + 1, n):
                    g.add_clause([-vars[i][j], -vars[k][j]])  # AMO

        # Main diagonals (r - c)
        for d in range(-n + 1, n):
            cells = []
            for r in range(n):
                c = r - d
                if 0 <= c < n:
                    cells.append(vars[r][c])
            for i in range(len(cells)):
                for j in range(i + 1, len(cells)):
                    g.add_clause([-cells[i], -cells[j]])

        # Anti diagonals (r + c)
        for d in range(2 * n - 1):
            cells = []
            for r in range(n):
                c = d - r
                if 0 <= c < n:
                    cells.append(vars[r][c])
            for i in range(len(cells)):
                for j in range(i + 1, len(cells)):
                    g.add_clause([-cells[i], -cells[j]])

        if g.solve():
            model = set(g.get_model())
            for i in range(n):
                row = ['.'] * n
                for j in range(n):
                    if vars[i][j] in model:
                        row[j] = 'Q'
                print(' '.join(row))
        else:
            print("UNSATISFIABLE")


solve_nqueens(10)




















import math
from pysat.solvers import Glucose3 


def solvers_sudoku(n, grid):
    g = Glucose3()
    
    s = int(math.sqrt(n))
    vars = [[[n*n*i + n*j + k + 1 for k in range (n)] for j in range (n)] for i in range (n)]
    for i in range(n):
        for j in range(n):
            if grid[i][j] != 0:
                g.add_clause([vars[i][j][grid[i][j] - 1]])
    #exactly one for one cell
    for i in range (n):
        for j in range (n):
            g.add_clause(vars[i][j])
            for k1 in range (n - 1):
                for k2 in range (k1 + 1, n):
                    g.add_clause([-vars[i][j][k1], -vars[i][j][k2]])
    #exactly one for each row
    for k in range(n):
        for i in range(n):
            g.add_clause([vars[i][j][k] for j in range (n)])
            for j1 in range (n):
                for j2 in range (j1 + 1, n):
                    g.add_clause([-vars[i][j1][k], -vars[i][j2][k]])
    #exactly one for each col
    for k in range(n):
        for j in range(n):
            g.add_clause([vars[i][j][k] for i in range (n)])
            for i1 in range (n):
                for i2 in range (i1 + 1, n):
                    g.add_clause([-vars[i1][j][k], -vars[i2][j][k]])

    #exactly one for cell sqrt(n) * sqrt(n)
    for k in range (n):
        for i in range (0, n, s):
            for j in range (0, n, s):
                g.add_clause([vars[i + d//s][j + d%s][k] for d in range (n)]) #(d//s, d%s) là toạn độ của ma trận 3 * 3, i, j là dịch ma trận 
                for id1 in range(n):
                    for id2 in range (id1 + 1, n):
                        g.add_clause([ -vars[i + id1//s][j + id1%s][k],
                                        -vars[i + id2//s][j + id2%s][k]])

    if g.solve():
        model = g.get_model()
        for i in range(n):
            for j in range(n):
                for k in range(n):
                    if vars[i][j][k] in model:
                        print(k+1, end = ' ')
            print("\n")
    else:
        print("UNSATISFIABLE")


grid = [
    [5,3,0,0,7,0,0,0,0],
    [6,0,0,1,9,5,0,0,0],
    [0,9,8,0,0,0,0,6,0],
    [8,0,0,0,6,0,0,0,3],
    [4,0,0,8,0,3,0,0,1],
    [7,0,0,0,2,0,0,0,6],
    [0,6,0,0,0,0,2,8,0],
    [0,0,0,4,1,9,0,0,5],
    [0,0,0,0,8,0,0,7,9],
]


solvers_sudoku(9, grid)






